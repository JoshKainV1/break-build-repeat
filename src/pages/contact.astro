---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <p class="font-mono text-sm text-zinc-500 mb-2">Get in touch</p>
    <h1 class="text-3xl font-bold text-zinc-100 mb-4">Contact</h1>
    <p class="text-zinc-400 mb-10">Whether it's a project, a job, or just to talk about breaking things — reach out.</p>

    <div class="space-y-4">
      <a
        href="https://github.com/JoshKainV1"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 border border-zinc-800 rounded-lg p-5 hover:border-zinc-500 hover:shadow-[0_0_30px_-5px_rgba(161,161,170,0.15)] transition-all duration-300 group"
      >
        <span class="font-mono text-zinc-500 text-sm w-20">GitHub</span>
        <span class="text-zinc-300 group-hover:text-white transition-colors">JoshKainV1</span>
        <span class="ml-auto text-xs text-zinc-600 group-hover:text-zinc-400 transition-colors">↗</span>
      </a>

      <!-- Email with copy button -->
      <div class="flex items-center gap-4 border border-zinc-800 rounded-lg p-5 hover:border-zinc-500 hover:shadow-[0_0_30px_-5px_rgba(161,161,170,0.15)] transition-all duration-300 group">
        <span class="font-mono text-zinc-500 text-sm w-20">Email</span>
        <a href="mailto:jkainV7@gmail.com" class="text-zinc-300 group-hover:text-white transition-colors">
          jkainV7@gmail.com
        </a>
        <button
          id="copy-email"
          class="ml-auto font-mono text-xs text-zinc-600 hover:text-zinc-300 transition-colors border border-zinc-800 hover:border-zinc-600 px-3 py-1 rounded"
        >
          copy
        </button>
      </div>
    </div>

    <!-- Keyboard shortcut hint -->
    <p class="font-mono text-xs text-zinc-700 mt-12">
      tip: press <kbd class="bg-zinc-900 border border-zinc-700 px-1.5 py-0.5 rounded text-zinc-500">g</kbd> then <kbd class="bg-zinc-900 border border-zinc-700 px-1.5 py-0.5 rounded text-zinc-500">h</kbd> <kbd class="bg-zinc-900 border border-zinc-700 px-1.5 py-0.5 rounded text-zinc-500">p</kbd> <kbd class="bg-zinc-900 border border-zinc-700 px-1.5 py-0.5 rounded text-zinc-500">a</kbd> <kbd class="bg-zinc-900 border border-zinc-700 px-1.5 py-0.5 rounded text-zinc-500">c</kbd> to navigate
    </p>
  </section>
</Layout>

<script>
  const btn = document.getElementById('copy-email');
  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('jkainV7@gmail.com');
    btn.textContent = 'copied!';
    btn.classList.add('text-green-400', 'border-green-800');
    setTimeout(() => {
      btn.textContent = 'copy';
      btn.classList.remove('text-green-400', 'border-green-800');
    }, 2000);
  });
</script>
