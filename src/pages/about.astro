---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profilePic from '../assets/profile_pic_under_1mb.jpg';
import FadeIn from '../components/FadeIn.astro';

const currently = [
  "Building out the homelab — Proxmox for virtualisation, OPNsense on the edge, TrueNAS for storage",
  "Getting properly good at IaC, with Kubernetes and WireGuard on the bench next to it",
  "Shipping projects and documenting the breakage on this site",
];

const toolbox = [
  { group: "Languages", items: ["C#", "JavaScript", "Python", "SQL"] },
  { group: "Frontend", items: ["React", "Astro", "Tailwind", "KnockoutJS"] },
  { group: "Infrastructure", items: ["Docker", "Azure DevOps", "OPNsense", "TrueNAS", "ZFS"] },
  { group: "Currently learning", items: ["IaC", "Proxmox", "Kubernetes", "WireGuard"] },
];

const experience = [
  {
    role: "Systems Engineer",
    company: "Clio",
    period: "Jul 2025 – Present",
    location: "Manchester · Hybrid",
    blurb: "Infrastructure, automation, and the CI/CD pipelines that keep production running. The person asking whether that deployment is going to cost someone a weekend in three months.",
    skills: ["Engineering", "Automation", "Azure DevOps", "C#", "IaC"],
  },
  {
    role: "Software Developer",
    company: "ShareDo",
    period: "Nov 2021 – Mar 2026",
    location: "Alderley Edge · Remote",
    blurb: "Four and a half years building a cloud case and matter management platform for large law firms — now Clio Operate — in C# and KnockoutJS. The years that taught me what happens to code after it ships.",
    skills: ["C#", "KnockoutJS", "JavaScript", "SQL"],
  },
  {
    role: "Software Developer",
    company: "Brainboxes Ltd",
    period: "Jun 2020 – Oct 2021",
    location: "",
    blurb: "First developer role after retraining, working on the BB-400 Industrial Edge Controller — an industrialised Raspberry Pi and Arduino with DIO, serial, Bluetooth, WiFi, NFC and Ethernet, a built-in UPS, and a secure web interface. Software that develops on a Pi at your desk and deploys to a DIN rail running at −25°C.",
    skills: ["Raspberry Pi", "Arduino", "IoT", "Edge computing"],
  },
  {
    role: "Internship Trainee",
    company: "Northcoders",
    period: "Mar 2019 – Jun 2019",
    location: "Manchester",
    blurb: "Completed the Northcoders course. Went in a barista working for the sake of working; came out with options and the ability to grow. Everything on this site traces back here.",
    skills: [],
  },
];
---

<Layout title="About">
  <section class="max-w-4xl mx-auto px-6 py-16">

    <!-- Hero row: photo + intro -->
    <FadeIn>
      <div class="flex flex-col md:flex-row gap-10 items-start mb-16">
        <div class="shrink-0">
          <Image
            src={profilePic}
            alt="Josh Kain"
            width={160}
            height={160}
            class="rounded-full border-2 border-zinc-800 object-cover w-36 h-36 md:w-40 md:h-40"
          />
        </div>
        <div>
          <p class="font-mono text-sm text-zinc-500 mb-2">The person behind the broken things</p>
          <h1 class="text-3xl font-bold text-zinc-100 mb-6">Josh Kain</h1>
          <div class="space-y-4 text-zinc-400 leading-relaxed">
            <p>
              Systems Engineer at Clio, based in Manchester. I ended up in infrastructure because I can't stand fighting systems: the whole point of platform work is making things so smooth that getting something up and running takes barely any effort. A good platform engineer isn't the hero fixing production at 2am — they're the reason nobody has to. The part that makes me lose track of time is the understanding: reading the docs, pulling a system apart until I know <em>why</em> it works, not just that it does.
            </p>
            <p>
              Started in tech the honest way — a Northcoders bootcamp, a barista who wanted options. Now I'm the person thinking about governance, IaC, and why that rushed deployment is going to cost someone a weekend in three months.
            </p>
            <p class="border-l-2 border-zinc-700 pl-4 italic text-zinc-300">
              "Move fast where you can. Never rush the infrastructure."
            </p>
            <p>
              Outside of work I'm building out a homelab — Proxmox for virtualisation, OPNsense on the network edge, TrueNAS for storage — where I self-host services, tinker with networking, and build things that sometimes work exactly as intended. This site is one of them.
            </p>
            <p>
              The same instinct runs the rest of the house: woodworking and DIY, doing everything I possibly can myself — learn the skill rather than pay someone. It turns out "read the docs and have a go" works on stud walls as well as it does on subnets.
            </p>
          </div>
        </div>
      </div>
    </FadeIn>

    <!-- Currently -->
    <FadeIn delay={100}>
      <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest mb-6">Currently</h2>
      <div class="border border-zinc-800 rounded-lg p-5 mb-16">
        <ul class="space-y-3">
          {currently.map(item => (
            <li class="flex items-start gap-3 text-zinc-400 text-sm leading-relaxed">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse shrink-0 mt-1.5"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </FadeIn>

    <!-- Toolbox -->
    <FadeIn delay={100}>
      <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest mb-6">Toolbox</h2>
      <div class="grid sm:grid-cols-2 gap-4 mb-16">
        {toolbox.map(({ group, items }) => (
          <div class="border border-zinc-800 rounded-lg p-5">
            <h3 class="font-mono text-xs text-zinc-500 uppercase tracking-widest mb-3">{group}</h3>
            <div class="flex gap-2 flex-wrap">
              {items.map(item => (
                <span class="text-xs font-mono text-zinc-400 bg-zinc-900 px-2 py-0.5 rounded">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </FadeIn>

    <!-- Experience -->
    <FadeIn delay={100}>
      <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest mb-6">Experience</h2>
    </FadeIn>
    <div class="space-y-4">
      {experience.map((job, i) => (
        <FadeIn delay={i * 80}>
          <div class="border border-zinc-800 rounded-lg p-5 hover:border-zinc-700 transition-colors">
            <div class="flex items-start justify-between mb-2">
              <div>
                <h3 class="font-semibold text-zinc-100">{job.role}</h3>
                <p class="text-zinc-400 text-sm">
                  {job.company}{job.location && <span class="text-zinc-600"> · {job.location}</span>}
                </p>
              </div>
              <span class="font-mono text-xs text-zinc-500 shrink-0 ml-4">{job.period}</span>
            </div>
            {job.blurb && (
              <p class="text-zinc-500 text-sm leading-relaxed mt-2">{job.blurb}</p>
            )}
            {job.skills.length > 0 && (
              <div class="flex gap-2 flex-wrap mt-3">
                {job.skills.map(skill => (
                  <span class="text-xs font-mono text-zinc-500 bg-zinc-900 px-2 py-0.5 rounded">{skill}</span>
                ))}
              </div>
            )}
          </div>
        </FadeIn>
      ))}
    </div>

    <!-- CTA -->
    <FadeIn delay={150}>
      <div class="mt-16 pt-10 border-t border-zinc-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <p class="text-zinc-400">
          Want to talk infrastructure, homelabs, or why the build is broken?
        </p>
        <div class="flex gap-4 shrink-0">
          <a href="/contact" class="bg-zinc-100 text-zinc-950 px-5 py-2.5 rounded text-sm font-medium hover:bg-white transition-colors">
            Get in touch
          </a>
          <a href="https://github.com/JoshKainV1" target="_blank" rel="noopener" class="border border-zinc-700 text-zinc-300 px-5 py-2.5 rounded text-sm font-medium hover:border-zinc-500 transition-colors">
            GitHub
          </a>
        </div>
      </div>
    </FadeIn>
  </section>
</Layout>
